
// ============================================================
// Alarion Hotels Management & Booking System
// Prisma schema — converted from DBML v1.0 (May 2026)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  guest
  hotel_admin
  super_admin

  @@map("user_role")
}

enum UserStatus {
  active
  inactive
  banned

  @@map("user_status")
}

enum HotelStatus {
  active
  inactive
  pending
  suspended

  @@map("hotel_status")
}

enum PropertyType {
  hotel
  resort
  boutique
  service_apartment

  @@map("property_type")
}

enum RoomStatus {
  active
  inactive
  maintenance

  @@map("room_status")
}

enum InventoryStatus {
  available
  blocked
  maintenance

  @@map("inventory_status")
}

enum BookingStatus {
  pending
  confirmed
  checked_in
  checked_out
  cancelled
  no_show
  expired

  @@map("booking_status")
}

enum PaymentStatus {
  pending
  authorized
  captured
  failed
  refund_initiated
  refunded
  partially_refunded

  @@map("payment_status")
}

enum PaymentMethod {
  upi
  credit_card
  debit_card
  net_banking
  wallet
  other

  @@map("payment_method")
}

enum ReviewStatus {
  pending
  approved
  rejected
  flagged

  @@map("review_status")
}

enum DiscountType {
  flat
  percentage

  @@map("discount_type")
}

enum CouponStatus {
  active
  inactive
  expired

  @@map("coupon_status")
}

enum BookingSource {
  platform_direct
  walkin
  stayflexi
  ota_booking_com
  ota_expedia
  ota_airbnb
  other

  @@map("booking_source")
}

enum SyncStatus {
  success
  failed
  pending
  in_progress

  @@map("sync_status")
}

enum SyncEntityType {
  reservation
  inventory
  rate
  property
  room_type
  rate_plan
  restriction

  @@map("sync_entity_type")
}

enum SyncOperation {
  pull
  push
  webhook
  full_sync

  @@map("sync_operation")
}

enum NotificationType {
  booking_confirmed
  booking_cancelled
  booking_reminder
  payment_received
  payment_refunded
  review_received
  review_response
  system_alert
  stayflexi_sync_error

  @@map("notification_type")
}

enum RatePlanMeal {
  room_only
  breakfast_included
  half_board
  full_board

  @@map("rate_plan_meal")
}

enum PricingRuleType {
  demand_based
  rule_based
  time_based

  @@map("pricing_rule_type")
}

enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday

  @@map("day_of_week")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String     @unique @db.VarChar(255)
  phone         String?    @unique @db.VarChar(15)
  passwordHash  String?    @map("password_hash") @db.VarChar(255)
  name          String     @db.VarChar(255)
  role          UserRole   @default(guest)
  status        UserStatus @default(active)
  emailVerified Boolean?   @default(false) @map("email_verified")
  phoneVerified Boolean?   @default(false) @map("phone_verified")
  avatarUrl     String?    @map("avatar_url") @db.VarChar(500)
  googleId      String?    @unique @map("google_id") @db.VarChar(255)
  lastLoginAt   DateTime?  @map("last_login_at") @db.Timestamp(6)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  sessions         UserSession[]
  addresses        UserAddress[]
  createdHotels    Hotel[]
  hotelAdmins      HotelAdmin[]
  bookings         Booking[]
  bookingNotes     BookingNote[]
  reviews          Review[]       @relation("ReviewAuthor")
  reviewResponses  Review[]       @relation("ReviewResponder")
  moderatedReviews Review[]       @relation("ReviewModerator")
  createdCoupons   Coupon[]
  couponUsages     CouponUsage[]
  savedHotels      SavedHotel[]
  notifications    Notification[]
  createdBanners   Banner[]
  auditLogs        AuditLog[]

  @@index([role])
  @@index([role, status])
  @@map("users")
}

model UserSession {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String   @unique @map("refresh_token") @db.VarChar(500)
  deviceInfo   String?  @map("device_info") @db.VarChar(500)
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  expiresAt    DateTime @map("expires_at") @db.Timestamp(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model UserAddress {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  label        String?  @db.VarChar(50)
  addressLine1 String   @map("address_line1") @db.VarChar(255)
  addressLine2 String?  @map("address_line2") @db.VarChar(255)
  city         String   @db.VarChar(100)
  state        String   @db.VarChar(100)
  pincode      String   @db.VarChar(10)
  isDefault    Boolean? @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_addresses")
}

// ============================================================
// CITIES & LOCATIONS
// ============================================================

model City {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(100)
  state        String   @db.VarChar(100)
  slug         String   @unique @db.VarChar(120)
  description  String?  @db.Text
  imageUrl     String?  @map("image_url") @db.VarChar(500)
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int?     @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  hotels Hotel[]

  @@index([isActive])
  @@index([isActive, displayOrder])
  @@map("cities")
}

// ============================================================
// HOTELS & PROPERTIES
// ============================================================

model Hotel {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String       @db.VarChar(255)
  legalName        String?      @map("legal_name") @db.VarChar(255)
  slug             String       @unique @db.VarChar(280)
  description      String?      @db.Text
  shortDescription String?      @map("short_description") @db.VarChar(500)
  addressLine1     String       @map("address_line1") @db.VarChar(255)
  addressLine2     String?      @map("address_line2") @db.VarChar(255)
  cityId           String       @map("city_id") @db.Uuid
  state            String       @db.VarChar(100)
  pincode          String       @db.VarChar(10)
  latitude         Decimal      @db.Decimal(10, 7)
  longitude        Decimal      @db.Decimal(10, 7)
  starRating       Int          @map("star_rating")
  propertyType     PropertyType @default(hotel) @map("property_type")
  contactPhone     String?      @map("contact_phone") @db.VarChar(15)
  contactEmail     String?      @map("contact_email") @db.VarChar(255)
  websiteUrl       String?      @map("website_url") @db.VarChar(500)
  gstNumber        String?      @map("gst_number") @db.VarChar(20)
  mainImageUrl     String?      @map("main_image_url") @db.VarChar(500)
  checkinTime      DateTime?    @default(dbgenerated("'14:00:00'::time")) @map("checkin_time") @db.Time(6)
  checkoutTime     DateTime?    @default(dbgenerated("'11:00:00'::time")) @map("checkout_time") @db.Time(6)
  commissionPct    Decimal      @default(15.00) @map("commission_pct") @db.Decimal(5, 2)
  status           HotelStatus  @default(pending)
  isFeatured       Boolean?     @default(false) @map("is_featured")
  avgRating        Decimal?     @default(0.00) @map("avg_rating") @db.Decimal(3, 2)
  totalReviews     Int?         @default(0) @map("total_reviews")
  createdById      String?      @map("created_by") @db.Uuid
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  city                City                 @relation(fields: [cityId], references: [id])
  createdBy           User?                @relation(fields: [createdById], references: [id])
  images              HotelImage[]
  policy              HotelPolicy?
  admins              HotelAdmin[]
  amenities           HotelAmenity[]
  roomTypes           RoomType[]
  ratePlans           RatePlan[]
  dynamicPricingRules DynamicPricingRule[]
  rateTemplates       RateTemplate[]
  bookings            Booking[]
  reviews             Review[]
  coupons             Coupon[]
  savedHotels         SavedHotel[]
  taxConfigs          TaxConfig[]
  stayflexiConfig     StayflexiConfig?
  stayflexiEntityMaps StayflexiEntityMap[]
  syncLogs            SyncLog[]

  @@index([cityId])
  @@index([cityId, status])
  @@index([status])
  @@index([status, isFeatured])
  @@index([starRating])
  @@index([propertyType])
  @@map("hotels")
}

model HotelImage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId      String   @map("hotel_id") @db.Uuid
  imageUrl     String   @map("image_url") @db.VarChar(500)
  caption      String?  @db.VarChar(255)
  displayOrder Int?     @default(0) @map("display_order")
  isPrimary    Boolean? @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@index([hotelId])
  @@index([hotelId, displayOrder])
  @@map("hotel_images")
}

model HotelPolicy {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId               String   @unique @map("hotel_id") @db.Uuid
  cancellationPolicy    String?  @map("cancellation_policy") @db.Text
  freeCancellationHours Int?     @default(24) @map("free_cancellation_hours")
  childPolicy           String?  @map("child_policy") @db.Text
  petPolicy             String?  @map("pet_policy") @db.Text
  smokingPolicy         String?  @map("smoking_policy") @db.VarChar(255)
  extraBedAvailable     Boolean? @default(false) @map("extra_bed_available")
  extraBedCharge        Decimal? @map("extra_bed_charge") @db.Decimal(10, 2)
  idProofRequired       Boolean? @default(true) @map("id_proof_required")
  acceptedIdTypes       Json?    @map("accepted_id_types") @db.JsonB
  customPolicies        Json?    @map("custom_policies") @db.JsonB
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@map("hotel_policies")
}

model HotelAdmin {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  role        String   @default("admin") @db.VarChar(50)
  permissions Json?    @db.JsonB
  isPrimary   Boolean? @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  hotel Hotel @relation(fields: [hotelId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([hotelId, userId])
  @@index([hotelId])
  @@index([userId])
  @@map("hotel_admins")
}

// ============================================================
// AMENITIES
// ============================================================

model Amenity {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(100)
  icon      String?  @db.VarChar(100)
  category  String   @db.VarChar(50)
  isActive  Boolean? @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  hotelAmenities HotelAmenity[]

  @@index([category])
  @@index([category, isActive])
  @@map("amenities")
}

model HotelAmenity {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId   String @map("hotel_id") @db.Uuid
  amenityId String @map("amenity_id") @db.Uuid

  hotel   Hotel   @relation(fields: [hotelId], references: [id])
  amenity Amenity @relation(fields: [amenityId], references: [id])

  @@unique([hotelId, amenityId])
  @@index([hotelId])
  @@map("hotel_amenities")
}

// ============================================================
// ROOMS & INVENTORY
// ============================================================

model RoomType {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId      String     @map("hotel_id") @db.Uuid
  name         String     @db.VarChar(150)
  description  String?    @db.Text
  bedType      String?    @map("bed_type") @db.VarChar(50)
  maxAdults    Int        @default(2) @map("max_adults")
  maxChildren  Int        @default(1) @map("max_children")
  maxOccupancy Int        @default(3) @map("max_occupancy")
  basePrice    Decimal    @map("base_price") @db.Decimal(10, 2)
  totalRooms   Int        @map("total_rooms")
  roomSizeSqft Int?       @map("room_size_sqft")
  floor        String?    @db.VarChar(50)
  viewType     String?    @map("view_type") @db.VarChar(100)
  amenities    Json?      @db.JsonB
  images       Json?      @db.JsonB
  status       RoomStatus @default(active)
  displayOrder Int?       @default(0) @map("display_order")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  hotel               Hotel                @relation(fields: [hotelId], references: [id])
  roomInventory       RoomInventory[]
  ratePlans           RatePlan[]
  roomRates           RoomRate[]
  dynamicPricingRules DynamicPricingRule[]
  bookings            Booking[]
  bookingRooms        BookingRoom[]

  @@index([hotelId])
  @@index([hotelId, status])
  @@index([hotelId, displayOrder])
  @@map("room_types")
}

model RoomInventory {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomTypeId   String          @map("room_type_id") @db.Uuid
  date         DateTime        @db.Date
  totalRooms   Int             @map("total_rooms")
  bookedRooms  Int             @default(0) @map("booked_rooms")
  blockedRooms Int             @default(0) @map("blocked_rooms")
  status       InventoryStatus @default(available)
  source       String?         @default("manual") @db.VarChar(50)
  updatedAt    DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  roomType RoomType @relation(fields: [roomTypeId], references: [id])

  @@unique([roomTypeId, date])
  @@index([date])
  @@index([roomTypeId, date, status])
  @@map("room_inventory")
}

// ============================================================
// RATES & PRICING
// ============================================================

model RatePlan {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId               String       @map("hotel_id") @db.Uuid
  roomTypeId            String       @map("room_type_id") @db.Uuid
  name                  String       @db.VarChar(150)
  description           String?      @db.Text
  mealIncluded          RatePlanMeal @default(room_only) @map("meal_included")
  isRefundable          Boolean      @default(true) @map("is_refundable")
  cancellationPolicy    String?      @map("cancellation_policy") @db.Text
  freeCancellationHours Int?         @map("free_cancellation_hours")
  priceModifierPct      Decimal?     @default(0.00) @map("price_modifier_pct") @db.Decimal(5, 2)
  isActive              Boolean?     @default(true) @map("is_active")
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  hotel     Hotel      @relation(fields: [hotelId], references: [id])
  roomType  RoomType   @relation(fields: [roomTypeId], references: [id])
  roomRates RoomRate[]
  bookings  Booking[]

  @@index([hotelId])
  @@index([roomTypeId])
  @@index([roomTypeId, isActive])
  @@map("rate_plans")
}

model RoomRate {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomTypeId        String   @map("room_type_id") @db.Uuid
  ratePlanId        String   @map("rate_plan_id") @db.Uuid
  date              DateTime @db.Date
  baseRate          Decimal  @map("base_rate") @db.Decimal(10, 2)
  finalRate         Decimal  @map("final_rate") @db.Decimal(10, 2)
  extraAdultCharge  Decimal? @default(0) @map("extra_adult_charge") @db.Decimal(10, 2)
  extraChildCharge  Decimal? @default(0) @map("extra_child_charge") @db.Decimal(10, 2)
  minLengthOfStay   Int?     @default(1) @map("min_length_of_stay")
  maxLengthOfStay   Int?     @map("max_length_of_stay")
  closedToArrival   Boolean? @default(false) @map("closed_to_arrival")
  closedToDeparture Boolean? @default(false) @map("closed_to_departure")
  source            String?  @default("manual") @db.VarChar(50)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  roomType RoomType @relation(fields: [roomTypeId], references: [id])
  ratePlan RatePlan @relation(fields: [ratePlanId], references: [id])

  @@unique([roomTypeId, ratePlanId, date])
  @@index([roomTypeId, date])
  @@index([date])
  @@map("room_rates")
}

model DynamicPricingRule {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId            String          @map("hotel_id") @db.Uuid
  name               String          @db.VarChar(150)
  ruleType           PricingRuleType @map("rule_type")
  roomTypeId         String?         @map("room_type_id") @db.Uuid
  isActive           Boolean?        @default(true) @map("is_active")
  occupancyMinPct    Int?            @map("occupancy_min_pct")
  occupancyMaxPct    Int?            @map("occupancy_max_pct")
  priceAdjustmentPct Decimal?        @map("price_adjustment_pct") @db.Decimal(5, 2)
  applicableDays     Json?           @map("applicable_days") @db.JsonB
  dateFrom           DateTime?       @map("date_from") @db.Date
  dateTo             DateTime?       @map("date_to") @db.Date
  timeSlots          Json?           @map("time_slots") @db.JsonB
  priority           Int?            @default(0)
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  hotel    Hotel     @relation(fields: [hotelId], references: [id])
  roomType RoomType? @relation(fields: [roomTypeId], references: [id])

  @@index([hotelId])
  @@index([hotelId, isActive])
  @@index([hotelId, ruleType])
  @@map("dynamic_pricing_rules")
}

model RateTemplate {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  name        String   @db.VarChar(150)
  description String?  @db.Text
  rates       Json     @db.JsonB
  isActive    Boolean? @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@index([hotelId])
  @@map("rate_templates")
}

// ============================================================
// BOOKINGS
// ============================================================

model Booking {
  id                     String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingRef             String        @unique @map("booking_ref") @db.VarChar(20)
  userId                 String        @map("user_id") @db.Uuid
  hotelId                String        @map("hotel_id") @db.Uuid
  roomTypeId             String        @map("room_type_id") @db.Uuid
  ratePlanId             String        @map("rate_plan_id") @db.Uuid
  checkinDate            DateTime      @map("checkin_date") @db.Date
  checkoutDate           DateTime      @map("checkout_date") @db.Date
  numRooms               Int           @default(1) @map("num_rooms")
  numAdults              Int           @default(1) @map("num_adults")
  numChildren            Int           @default(0) @map("num_children")
  numNights              Int           @map("num_nights")
  guestName              String        @map("guest_name") @db.VarChar(255)
  guestEmail             String        @map("guest_email") @db.VarChar(255)
  guestPhone             String?       @map("guest_phone") @db.VarChar(15)
  specialRequests        String?       @map("special_requests") @db.Text
  roomTotal              Decimal       @map("room_total") @db.Decimal(10, 2)
  taxAmount              Decimal       @default(0) @map("tax_amount") @db.Decimal(10, 2)
  discountAmount         Decimal       @default(0) @map("discount_amount") @db.Decimal(10, 2)
  totalAmount            Decimal       @map("total_amount") @db.Decimal(10, 2)
  couponId               String?       @map("coupon_id") @db.Uuid
  status                 BookingStatus @default(pending)
  paymentStatus          PaymentStatus @default(pending) @map("payment_status")
  source                 BookingSource @default(platform_direct)
  cancelledAt            DateTime?     @map("cancelled_at") @db.Timestamp(6)
  cancellationReason     String?       @map("cancellation_reason") @db.Text
  refundAmount           Decimal?      @map("refund_amount") @db.Decimal(10, 2)
  stayflexiReservationId String?       @map("stayflexi_reservation_id") @db.VarChar(100)
  confirmedAt            DateTime?     @map("confirmed_at") @db.Timestamp(6)
  checkedInAt            DateTime?     @map("checked_in_at") @db.Timestamp(6)
  checkedOutAt           DateTime?     @map("checked_out_at") @db.Timestamp(6)
  holdExpiresAt          DateTime?     @map("hold_expires_at") @db.Timestamp(6)
  createdAt              DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt              DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  user              User               @relation(fields: [userId], references: [id])
  hotel             Hotel              @relation(fields: [hotelId], references: [id])
  roomType          RoomType           @relation(fields: [roomTypeId], references: [id])
  ratePlan          RatePlan           @relation(fields: [ratePlanId], references: [id])
  coupon            Coupon?            @relation(fields: [couponId], references: [id])
  bookingRooms      BookingRoom[]
  bookingNightRates BookingNightRate[]
  bookingNotes      BookingNote[]
  payments          Payment[]
  refunds           Refund[]
  review            Review?
  couponUsages      CouponUsage[]

  @@index([userId])
  @@index([hotelId])
  @@index([hotelId, checkinDate, checkoutDate])
  @@index([hotelId, status])
  @@index([status])
  @@index([paymentStatus])
  @@index([checkinDate, checkoutDate])
  @@index([source])
  @@index([createdAt])
  @@map("bookings")
}

model BookingRoom {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId    String  @map("booking_id") @db.Uuid
  roomTypeId   String  @map("room_type_id") @db.Uuid
  roomNumber   String? @map("room_number") @db.VarChar(20)
  perNightRate Decimal @map("per_night_rate") @db.Decimal(10, 2)
  nights       Int
  subtotal     Decimal @db.Decimal(10, 2)

  booking  Booking  @relation(fields: [bookingId], references: [id])
  roomType RoomType @relation(fields: [roomTypeId], references: [id])

  @@index([bookingId])
  @@map("booking_rooms")
}

model BookingNightRate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId String   @map("booking_id") @db.Uuid
  date      DateTime @db.Date
  rate      Decimal  @db.Decimal(10, 2)
  tax       Decimal  @default(0) @db.Decimal(10, 2)

  booking Booking @relation(fields: [bookingId], references: [id])

  @@unique([bookingId, date])
  @@index([bookingId])
  @@map("booking_night_rates")
}

model BookingNote {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId  String   @map("booking_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  note       String   @db.Text
  isInternal Boolean? @default(true) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  booking Booking @relation(fields: [bookingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([bookingId])
  @@map("booking_notes")
}

// ============================================================
// PAYMENTS
// ============================================================

model Payment {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId         String         @map("booking_id") @db.Uuid
  razorpayOrderId   String?        @unique @map("razorpay_order_id") @db.VarChar(100)
  razorpayPaymentId String?        @unique @map("razorpay_payment_id") @db.VarChar(100)
  razorpaySignature String?        @map("razorpay_signature") @db.VarChar(255)
  amount            Decimal        @db.Decimal(10, 2)
  currency          String         @default("INR") @db.VarChar(3)
  method            PaymentMethod?
  status            PaymentStatus  @default(pending)
  failureReason     String?        @map("failure_reason") @db.VarChar(500)
  metadata          Json?          @db.JsonB
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  booking Booking  @relation(fields: [bookingId], references: [id])
  refunds Refund[]

  @@index([bookingId])
  @@index([status])
  @@map("payments")
}

model Refund {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentId        String    @map("payment_id") @db.Uuid
  bookingId        String    @map("booking_id") @db.Uuid
  razorpayRefundId String?   @unique @map("razorpay_refund_id") @db.VarChar(100)
  amount           Decimal   @db.Decimal(10, 2)
  reason           String?   @db.Text
  status           String    @default("initiated") @db.VarChar(20)
  processedAt      DateTime? @map("processed_at") @db.Timestamp(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  payment Payment @relation(fields: [paymentId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([paymentId])
  @@index([bookingId])
  @@map("refunds")
}

// ============================================================
// REVIEWS & RATINGS
// ============================================================

model Review {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId         String       @unique @map("booking_id") @db.Uuid
  userId            String       @map("user_id") @db.Uuid
  hotelId           String       @map("hotel_id") @db.Uuid
  overallRating     Decimal      @map("overall_rating") @db.Decimal(2, 1)
  cleanlinessRating Decimal?     @map("cleanliness_rating") @db.Decimal(2, 1)
  serviceRating     Decimal?     @map("service_rating") @db.Decimal(2, 1)
  locationRating    Decimal?     @map("location_rating") @db.Decimal(2, 1)
  valueRating       Decimal?     @map("value_rating") @db.Decimal(2, 1)
  amenitiesRating   Decimal?     @map("amenities_rating") @db.Decimal(2, 1)
  comment           String?      @db.Text
  photos            Json?        @db.JsonB
  hotelResponse     String?      @map("hotel_response") @db.Text
  hotelResponseAt   DateTime?    @map("hotel_response_at") @db.Timestamp(6)
  hotelResponseById String?      @map("hotel_response_by") @db.Uuid
  status            ReviewStatus @default(pending)
  moderatedById     String?      @map("moderated_by") @db.Uuid
  moderatedAt       DateTime?    @map("moderated_at") @db.Timestamp(6)
  moderationNote    String?      @map("moderation_note") @db.Text
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  booking         Booking @relation(fields: [bookingId], references: [id])
  user            User    @relation("ReviewAuthor", fields: [userId], references: [id])
  hotel           Hotel   @relation(fields: [hotelId], references: [id])
  hotelResponseBy User?   @relation("ReviewResponder", fields: [hotelResponseById], references: [id])
  moderatedBy     User?   @relation("ReviewModerator", fields: [moderatedById], references: [id])

  @@index([hotelId])
  @@index([userId])
  @@index([hotelId, status])
  @@index([hotelId, overallRating])
  @@index([createdAt])
  @@map("reviews")
}

// ============================================================
// COUPONS & PROMOTIONS
// ============================================================

model Coupon {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String       @unique @db.VarChar(30)
  description         String?      @db.Text
  discountType        DiscountType @map("discount_type")
  discountValue       Decimal      @map("discount_value") @db.Decimal(10, 2)
  minOrderAmount      Decimal?     @default(0) @map("min_order_amount") @db.Decimal(10, 2)
  maxDiscount         Decimal?     @map("max_discount") @db.Decimal(10, 2)
  validFrom           DateTime     @map("valid_from") @db.Timestamp(6)
  validTo             DateTime     @map("valid_to") @db.Timestamp(6)
  usageLimit          Int?         @map("usage_limit")
  perUserLimit        Int?         @default(1) @map("per_user_limit")
  usedCount           Int          @default(0) @map("used_count")
  hotelId             String?      @map("hotel_id") @db.Uuid
  applicableRoomTypes Json?        @map("applicable_room_types") @db.JsonB
  status              CouponStatus @default(active)
  createdById         String?      @map("created_by") @db.Uuid
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  hotel        Hotel?        @relation(fields: [hotelId], references: [id])
  createdBy    User?         @relation(fields: [createdById], references: [id])
  bookings     Booking[]
  couponUsages CouponUsage[]

  @@index([status, validFrom, validTo])
  @@index([hotelId])
  @@map("coupons")
}

model CouponUsage {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couponId        String   @map("coupon_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  bookingId       String   @map("booking_id") @db.Uuid
  discountApplied Decimal  @map("discount_applied") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  coupon  Coupon  @relation(fields: [couponId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([couponId])
  @@index([userId])
  @@index([couponId, userId])
  @@map("coupon_usage")
}

// ============================================================
// SAVED / WISHLIST
// ============================================================

model SavedHotel {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  hotelId   String   @map("hotel_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user  User  @relation(fields: [userId], references: [id])
  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@unique([userId, hotelId])
  @@index([userId])
  @@map("saved_hotels")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(255)
  message   String           @db.Text
  data      Json?            @db.JsonB
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at") @db.Timestamp(6)
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ============================================================
// TAX CONFIGURATION
// ============================================================

model TaxConfig {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId   String?  @map("hotel_id") @db.Uuid
  name      String   @db.VarChar(100)
  ratePct   Decimal  @map("rate_pct") @db.Decimal(5, 2)
  minTariff Decimal? @map("min_tariff") @db.Decimal(10, 2)
  maxTariff Decimal? @map("max_tariff") @db.Decimal(10, 2)
  isActive  Boolean? @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  hotel Hotel? @relation(fields: [hotelId], references: [id])

  @@index([hotelId])
  @@index([hotelId, isActive])
  @@map("tax_configs")
}

// ============================================================
// STAYFLEXI CHANNEL MANAGER INTEGRATION
// ============================================================

model StayflexiConfig {
  id                    String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId               String      @unique @map("hotel_id") @db.Uuid
  apiKeyEncrypted       String      @map("api_key_encrypted") @db.VarChar(500)
  apiSecretEncrypted    String      @map("api_secret_encrypted") @db.VarChar(500)
  propertyId            String      @map("property_id") @db.VarChar(100)
  isActive              Boolean     @default(false) @map("is_active")
  lastFullSyncAt        DateTime?   @map("last_full_sync_at") @db.Timestamp(6)
  lastIncrementalSyncAt DateTime?   @map("last_incremental_sync_at") @db.Timestamp(6)
  syncStatus            SyncStatus? @default(pending) @map("sync_status")
  syncErrorMessage      String?     @map("sync_error_message") @db.Text
  webhookSecret         String?     @map("webhook_secret") @db.VarChar(255)
  createdAt             DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@index([isActive])
  @@map("stayflexi_configs")
}

model StayflexiEntityMap {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId      String         @map("hotel_id") @db.Uuid
  entityType   SyncEntityType @map("entity_type")
  localId      String         @map("local_id") @db.Uuid
  stayflexiId  String         @map("stayflexi_id") @db.VarChar(100)
  lastSyncedAt DateTime?      @map("last_synced_at") @db.Timestamp(6)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@unique([hotelId, entityType, localId])
  @@unique([hotelId, entityType, stayflexiId])
  @@index([hotelId])
  @@map("stayflexi_entity_map")
}

model SyncLog {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId         String         @map("hotel_id") @db.Uuid
  source          String         @db.VarChar(50)
  entityType      SyncEntityType @map("entity_type")
  entityId        String?        @map("entity_id") @db.VarChar(100)
  operation       SyncOperation
  requestPayload  Json?          @map("request_payload") @db.JsonB
  responsePayload Json?          @map("response_payload") @db.JsonB
  status          SyncStatus
  errorMessage    String?        @map("error_message") @db.Text
  retryCount      Int?           @default(0) @map("retry_count")
  nextRetryAt     DateTime?      @map("next_retry_at") @db.Timestamp(6)
  durationMs      Int?           @map("duration_ms")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamp(6)

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@index([hotelId])
  @@index([hotelId, entityType])
  @@index([hotelId, status])
  @@index([status, nextRetryAt])
  @@index([createdAt])
  @@map("sync_logs")
}

// ============================================================
// PLATFORM CONTENT & CONFIGURATION
// ============================================================

model Banner {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String    @db.VarChar(255)
  subtitle     String?   @db.VarChar(500)
  imageUrl     String    @map("image_url") @db.VarChar(500)
  linkUrl      String?   @map("link_url") @db.VarChar(500)
  displayOrder Int?      @default(0) @map("display_order")
  isActive     Boolean?  @default(true) @map("is_active")
  startsAt     DateTime? @map("starts_at") @db.Timestamp(6)
  endsAt       DateTime? @map("ends_at") @db.Timestamp(6)
  createdById  String?   @map("created_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  createdBy User? @relation(fields: [createdById], references: [id])

  @@index([isActive])
  @@index([isActive, displayOrder])
  @@map("banners")
}

model EmailTemplate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @db.VarChar(100)
  subject   String   @db.VarChar(500)
  htmlBody  String   @map("html_body") @db.Text
  variables Json?    @db.JsonB
  isActive  Boolean? @default(true) @map("is_active")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("email_templates")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  oldValues  Json?    @map("old_values") @db.JsonB
  newValues  Json?    @map("new_values") @db.JsonB
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
